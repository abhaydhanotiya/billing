# Copy to .env and adjust. The server reads these at startup.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sanskar?schema=public"
PORT=4000
HOST=0.0.0.0
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRY="12h"
CORS_ORIGIN="*"
INVOICE_PREFIX_GST="SR"
INVOICE_PREFIX_NONGST="SRE"
NODE_ENV="development"
